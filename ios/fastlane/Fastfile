default_platform(:ios)

# Builds an App Store Connect API key payload that match / pilot can consume.
# Locally: set ASC_API_KEY_FILEPATH to the on-disk .p8.
# In CI:    set APP_STORE_CONNECT_API_KEY_BASE64 to the base64 of the .p8.
# (Same env-name convention as tankstellen — deliberately distinct from
# fastlane's auto-discovered APP_STORE_CONNECT_API_KEY_PATH.)
def asc_api_key
  base64_content = ENV["APP_STORE_CONNECT_API_KEY_BASE64"]
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
    key_filepath: ENV["ASC_API_KEY_FILEPATH"],
    key_content: base64_content,
    is_key_content_base64: !base64_content.nil?,
    in_house: false,
  )
end

platform :ios do
  desc "Fetch the appstore distribution cert + profile (readonly on CI)."
  lane :match_appstore do
    match(type: "appstore", api_key: asc_api_key)
  end

  desc "One-time bootstrap on a trusted workstation: generate certs/profiles."
  lane :match_bootstrap do
    UI.user_error!("Refusing to bootstrap from CI — run this lane locally") if ENV["CI"] == "true"
    key = asc_api_key
    match(type: "development", api_key: key, readonly: false)
    match(type: "appstore", api_key: key, readonly: false)
  end

  desc "Repair/init: (re)generate the appstore profile for de.deskilo.app into"
  desc "the shared certs repo. Registers the bundle id at Apple if missing."
  desc "Needs a WRITE deploy key. Run via the workflow's sync_certs input."
  lane :match_sync_appstore do
    # force: true so entitlement changes are picked up too (tankstellen #3467).
    match(type: "appstore", api_key: asc_api_key, readonly: false, force: true)
  end

  desc "Build a signed appstore-distribution IPA (match_appstore ran first)."
  lane :build_appstore do |options|
    build_number = options[:build_number] || ENV["IOS_BUILD_NUMBER"] || Time.now.strftime("%Y%m%d")
    profile_name = ENV["sigh_de.deskilo.app_appstore_profile-name"] || "match AppStore de.deskilo.app"

    # Unique CFBundleVersion per upload — ASC rejects re-uploads of the same.
    increment_build_number(
      xcodeproj: "Runner.xcodeproj",
      build_number: build_number,
    )

    # `flutter build ipa` doesn't expose manual-signing options for
    # match-managed certs, so build with Flutter (no codesign) and let gym
    # drive xcodebuild. Bundler env is stripped so flutter's internal
    # `pod install` finds a loadable CocoaPods (tankstellen lesson).
    Bundler.with_unbundled_env do
      sh("flutter build ios --release --no-codesign " \
         "--obfuscate --split-debug-info=../build/symbols")
    end

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      output_directory: "../build/ios/ipa",
      output_name: "Runner.ipa",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "de.deskilo.app" => profile_name,
        },
        signingStyle: "manual",
        teamID: "C4Y5RDF8P9",
      },
      clean: false,
      include_symbols: true,
      include_bitcode: false,
    )
  end

  desc "Upload build/ios/ipa/Runner.ipa to TestFlight (internal testers only,"
  desc "no review). External groups come later — mirror tankstellen's"
  desc "upload_testflight when the time comes."
  lane :upload_testflight do |options|
    changelog = options[:changelog] || ENV["TESTFLIGHT_CHANGELOG"] || "Internal build."
    pilot(
      api_key: asc_api_key,
      app_identifier: "de.deskilo.app",
      team_id: "C4Y5RDF8P9",
      ipa: "../build/ios/ipa/Runner.ipa",
      changelog: changelog,
      distribute_external: false,
      # Internal-only upload: nothing to review, skip the processing wait.
      skip_waiting_for_build_processing: true,
    )
  end

  desc "End-to-end CI release: fetch certs, build, upload to TestFlight."
  lane :release_testflight do |options|
    match(type: "appstore", api_key: asc_api_key)
    build_appstore(build_number: options[:build_number])
    upload_testflight(changelog: options[:changelog])
  end
end
