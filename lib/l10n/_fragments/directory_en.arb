{
  "@@locale": "en",
  "directoryTitle": "Members",
  "@directoryTitle": {
    "description": "Member directory title: bottom-tab label and app-bar title of the Members tab (#230) plus its settings entry (#224), visible to every member. Keep it short — it must fit a bottom-bar tab."
  },
  "directoryEmpty": "No members yet.",
  "@directoryEmpty": {
    "description": "Empty state of the member directory"
  },
  "directoryCheckedIn": "Checked in",
  "@directoryCheckedIn": {
    "description": "Directory status chip: member is checked in right now (seat name unknown)"
  },
  "directoryCheckedInSeat": "Checked in · {seat}",
  "@directoryCheckedInSeat": {
    "description": "Directory status chip: member is checked in right now on the named seat/office",
    "placeholders": {
      "seat": {
        "type": "String"
      }
    }
  },
  "directoryOnline": "Online",
  "@directoryOnline": {
    "description": "Directory status chip: heartbeat younger than the presence window (#223)"
  },
  "directoryReservedToday": "Reserved today",
  "@directoryReservedToday": {
    "description": "Directory status chip: member has an active reservation later today"
  },
  "directoryLastSeenMinutes": "{minutes} min",
  "@directoryLastSeenMinutes": {
    "description": "Directory offline chip: compact relative last-seen, under an hour",
    "placeholders": {
      "minutes": {
        "type": "int"
      }
    }
  },
  "directoryLastSeenHours": "{hours} h",
  "@directoryLastSeenHours": {
    "description": "Directory offline chip: compact relative last-seen, under a day",
    "placeholders": {
      "hours": {
        "type": "int"
      }
    }
  },
  "directoryLastSeenDays": "{days} d",
  "@directoryLastSeenDays": {
    "description": "Directory offline chip: compact relative last-seen, a day or more",
    "placeholders": {
      "days": {
        "type": "int"
      }
    }
  },
  "directoryWhatsapp": "Chat on WhatsApp",
  "@directoryWhatsapp": {
    "description": "Tooltip of the wa.me contact button on a directory row (#223 opt-in); also the swipe-right background label and the contact button in the member detail sheet (#232)"
  },
  "directoryOpenGroup": "Open WhatsApp group",
  "@directoryOpenGroup": {
    "description": "Tile above the directory list opening the owner-configured WhatsApp group invite link (#231/#232); shown to every member, hidden when no link is set"
  },
  "directoryClose": "Close",
  "@directoryClose": {
    "description": "Dismiss button of the member detail sheet (#232)"
  },
  "directoryReservedNow": "Reserved now",
  "@directoryReservedNow": {
    "description": "Directory reservation chip (#237): an active reservation covers now but the member has not checked in (seat name unknown)"
  },
  "directoryReservedNowSeat": "Reserved now · {seat}",
  "@directoryReservedNowSeat": {
    "description": "Directory reservation chip (#237): an active reservation on the named seat/office covers now but the member has not checked in",
    "placeholders": {
      "seat": {
        "type": "String"
      }
    }
  }
